#include<iostream>
using namespace std;
int main()
{
   int k,i,j,n;
   int w[10][10],d[10][10];
   cout << "Enter number of rows and columns" << endl;
   cin >> n;
   for(i=0; i<n; i++) {
      for(j=0; j<n; j++) {
         cin >> w[i][j];
         d[i][j] = w[i][j];
      }
   }
   for(k=0; k<n; k++) {
      for(i=0; i<n; i++) {
         for(j=0; j<n; j++) {
            if (i != j) {
               if (d[i][k] != 0 && d[k][j] != 0) {
                  int new_dist = d[i][k] + d[k][j];
                  if (d[i][j] == 0 || d[i][j] > new_dist) {
                     d[i][j] = new_dist;
                  }
               }
            }
         }
      }
   }
   cout << "shortest path matrix" << endl;
   for(i=0; i<n; i++) {
      for(j=0; j<n; j++) {
         cout << d[i][j] << " ";
      }
      cout << endl;
   }
   return 0;
}
