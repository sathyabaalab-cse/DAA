#include<iostream>
using namespace std;
int main()
{
   int a[100],n;
   int i,j,v;
   cout<<"Enter number of elements\n";
   cin>>n;
   cout<<"Enter the elements\n";
   for(i=0;i<n;i++)
   {
      cin>>a[i];
   }
   for(i=1;i<n;i++)
   {
      v=a[i];
      j=i-1;
      while(j>=0 && a[j]>v)
      {
         a[j+1]=a[j];
         j=j-1;
      }
      a[j+1]=v;
   }
   cout<<"SORTED ARRAY\n";
   for(i=0;i<n;i++)
   {
      cout << a[i] << " ";
   }
   return 0;
}
