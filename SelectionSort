#include<iostream>
using namespace std;
int main()
{
   int n,i,min;
   cout<<"Enter number of elements\n";
   cin>>n;
   int a[n];
   cout<<"Enter the elements\n";
   for(int i=0;i<n;i++)
   {
      cin>>a[i];
   }
   for(int i=0;i<n-1;i++)
   {
      min=i;
      for(int j=i+1;j<n;j++)
      {
         if(a[j]<a[min])
         {
            min=j;
         }
      }
      if(min!=i)
      {
         int temp=a[i];
         a[i]=a[min];
         a[min]=temp;
      }
   }
   cout<<"Sorted Array\n";
   for(int i=0;i<n;i++)
      cout<<a[i]<<"\n";
   return 0;
}
